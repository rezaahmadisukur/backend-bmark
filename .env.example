# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://USER:PASSOWRD@localhost:5432/DB_NAME"

# ===========================================
# SERVER
# ===========================================
# Port untuk NestJS server
PORT=4000

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Secret key untuk signing JWT tokens
# Generate dengan: openssl rand -hex 32 / openssl rand -base64 50
# PENTING: Minimal 32 karakter untuk production!
JWT_SECRET=your-secret-key-here-min-32-chars

# JWT token expiration time
# Format: <number><unit>
# Unit: s (detik), m (menit), h (jam), d (hari)
# Contoh: 7d = 7 hari, 15m = 15 menit, 1h = 1 jam, 30s = 30 detik
JWT_ACCESS_EXPIRES_IN=7d

# ===========================================
# ENVIRONMENT
# ===========================================
# Allowed values: development | production | test
NODE_ENV=development
